import std.command
import std.path_fs

def command_construction_smoke(): Bool = {
  val command = core0_command(core0_path_from_string("c++"));
  command.arg("-c");
  command.arg("main.cc");
  command.env_var("COSMO_STAGE", "link");
  command.current_dir(core0_path_from_string("build"));

  core0_path_display(command.executable) == "c++" and
    command.args.len() == 2 and
    command.args.get(0) == "-c" and
    command.args.get(1) == "main.cc" and
    command.env.len() == 1 and
    command.env.get(0).key == "COSMO_STAGE"
}

def command_result_smoke(): Bool = {
  val ok = command_result(0, "compiled\n", "");
  val failed = command_result(1, "", "compile failed\n");

  ok.success() and failed.success() == false
}

def command_mocked_runtime_shape(): Result[CommandResult, CommandError] = {
  Result[CommandResult, CommandError]::Ok(command_result(0, "ok\n", ""))
}
