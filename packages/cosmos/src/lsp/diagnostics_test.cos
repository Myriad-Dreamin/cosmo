import lsp.diagnostics
import lsp.lifecycle
import workspace.documents

def cosmos_test_parser_diagnostic_fixture(): Bool = {
  val snapshot = cosmos_text_document_snapshot(
    "file:///repo/packages/app/src/main.cos",
    "/repo/packages/app/src/main.cos",
    1,
    "val =",
    "/repo/packages/app",
    "main",
    true
  );
  val diagnostics = cosmos_analyze_document(snapshot);
  if (diagnostics.len() != 1) {
    return false
  }

  val json = cosmos_lsp_diagnostics_json(diagnostics);
  json_contains(json, "\"code\":\"cosmo1.parser.expected\"") and
    json_contains(json, "\"severity\":1") and
    json_contains(json, "\"source\":\"cosmoc\"")
}

def cosmos_test_checker_diagnostic_fixture(): Bool = {
  val snapshot = cosmos_text_document_snapshot(
    "file:///repo/packages/app/src/main.cos",
    "/repo/packages/app/src/main.cos",
    1,
    "def main(): i32 = { false }",
    "/repo/packages/app",
    "main",
    true
  );
  val diagnostics = cosmos_analyze_document(snapshot);
  if (diagnostics.len() != 1) {
    return false
  }

  val first = diagnostics.get(0);
  first.message == "type mismatch" and
    cosmos_lsp_diagnostics_json(diagnostics) == cosmos_lsp_diagnostics_json(cosmos_analyze_document(snapshot))
}

def cosmos_test_helloworld_sample_has_no_diagnostics(): Bool = {
  val diagnostics = cosmos_analyze_document(cosmos_helloworld_sample_snapshot(cosmos_helloworld_sample_source()));
  if (diagnostics.len() != 0) {
    return false
  }

  val json = cosmos_lsp_diagnostics_json(diagnostics);
  json == "[]" and !cosmos_text_contains_any(json, cosmos_helloworld_false_positive_codes())
}

def cosmos_test_helloworld_invalid_edit_reports_parser_diagnostic(): Bool = {
  val diagnostics = cosmos_analyze_document(cosmos_helloworld_sample_snapshot("val ="));
  if (diagnostics.len() == 0) {
    return false
  }

  val json = cosmos_lsp_diagnostics_json(diagnostics);
  json_contains(json, "\"code\":\"cosmo1.parser.expected\"")
}

def cosmos_test_checker_gap_cascades_are_suppressed(): Bool = {
  val source = "def main() = {\n".concat(
    "  println(\"Hello, World!\")\n".concat(
      "  val x = 1\n".concat(
        "  println(x);\n".concat(
          "}"
        )
      )
    )
  );
  val diagnostics = cosmos_analyze_document(cosmos_helloworld_sample_snapshot(source));
  cosmos_lsp_diagnostics_json(diagnostics) == "[]"
}

def cosmos_test_package_diagnostic_fixture(): Bool = {
  val imports = Vec[String]();
  imports.push("missing");
  val modules = Vec[CosmosPackageModuleInput]();
  modules.push(CosmosPackageModuleInput("main", imports));

  val diagnostics = cosmos_analyze_package_graph(modules);
  diagnostics.len() == 1 and
    cosmos_lsp_diagnostics_json(diagnostics) == cosmos_lsp_diagnostics_json(cosmos_analyze_package_graph(modules)) and
    json_contains(cosmos_lsp_diagnostics_json(diagnostics), "\"code\":\"cosmo1.package.missing-import\"")
}

def cosmos_helloworld_sample_snapshot(source: String): CosmosTextDocumentSnapshot = {
  cosmos_text_document_snapshot(
    "file:///repo/samples/HelloWorld/main.cos",
    "/repo/samples/HelloWorld/main.cos",
    1,
    source,
    "/repo/samples",
    "HelloWorld/main",
    true
  )
}

def cosmos_helloworld_sample_source(): String = {
  "\n".concat(
    "def main() = {\n".concat(
      "  println(\"Hello, World!\")\n".concat(
        "\n".concat(
          "  val x = 1\n".concat(
            "  val y = 2\n".concat(
              "  val z = x + y\n".concat(
                "  println(z);\n".concat(
                  "}\n"
                )
              )
            )
          )
        )
      )
    )
  )
}

def cosmos_helloworld_false_positive_codes(): Vec[String] = {
  val codes = Vec[String]();
  codes.push("cosmo1.type.unsupported-name");
  codes.push("cosmo1.type.invalid-assignment-target");
  codes.push("cosmo1.type.missing-return");
  codes
}

def cosmos_text_contains_any(text: String, needles: Vec[String]): Bool = {
  for (needle in needles) {
    if (json_contains(text, needle)) {
      return true
    }
  }
  false
}

def cosmos_test_publish_and_clear_diagnostics(): Bool = {
  val snapshot = cosmos_diagnostic_test_snapshot("file:///repo/packages/app/src/main.cos", 1, "val =", true);
  val closed = cosmos_text_document_snapshot(
    snapshot.uri,
    snapshot.file_path,
    snapshot.version,
    snapshot.text,
    snapshot.package_root,
    snapshot.module_path,
    false
  );
  var server = lsp_server();
  val state = cosmos_diagnostics_state();

  server = state.publish_snapshot(server, snapshot);
  server = state.publish_snapshot(server, closed);

  server.outbound_len() == 2 and
    state.has_published(snapshot.uri) and
    server.session.outbound.get(1) == "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":\"file:///repo/packages/app/src/main.cos\",\"diagnostics\":[]}}"
}

def cosmos_test_publish_refresh_keeps_other_document(): Bool = {
  val first = cosmos_diagnostic_test_snapshot("file:///repo/packages/app/src/main.cos", 1, "val =", true);
  val second = cosmos_diagnostic_test_snapshot("file:///repo/packages/app/src/second.cos", 1, "def main(): i32 = { false }", true);
  var server = lsp_server();
  val state = cosmos_diagnostics_state();

  server = state.publish_snapshot(server, first);
  server = state.publish_snapshot(server, second);
  server = state.publish_snapshot(server, first);

  if (server.outbound_len() != 3) {
    return false
  }
  if (!state.has_published(first.uri) or !state.has_published(second.uri)) {
    return false
  }

  val first_refresh = server.session.outbound.get(2);
  json_contains(first_refresh, "\"uri\":\"file:///repo/packages/app/src/main.cos\"") and
    json_contains(first_refresh, "\"code\":\"cosmo1.parser.expected\"") and
    !json_contains(first_refresh, "\"uri\":\"file:///repo/packages/app/src/second.cos\"")
}

def cosmos_test_unchanged_refresh_is_stable(): Bool = {
  val snapshot = cosmos_diagnostic_test_snapshot("file:///repo/packages/app/src/main.cos", 7, "val =", true);
  var server = lsp_server();
  val state = cosmos_diagnostics_state();

  server = state.publish_snapshot(server, snapshot);
  server = state.publish_snapshot(server, snapshot);

  if (server.outbound_len() != 2) {
    return false
  }

  server.session.outbound.get(0) == server.session.outbound.get(1)
}

def cosmos_test_diagnostics_normalize_uri(): Bool = {
  val snapshot = cosmos_diagnostic_test_snapshot("file:///repo/packages/app/src/main%20file.cos", 1, "val =", true);
  var server = lsp_server();
  val state = cosmos_diagnostics_state();

  server = state.publish_snapshot(server, snapshot);

  state.has_published("file:///repo/packages/app/src/main file.cos") and
    json_contains(server.session.outbound.get(0), "\"uri\":\"file:///repo/packages/app/src/main%20file.cos\"")
}

def cosmos_diagnostic_test_snapshot(uri: String, version: i32, text: String, is_open: Bool): CosmosTextDocumentSnapshot = {
  cosmos_text_document_snapshot(
    uri,
    "/repo/packages/app/src/main.cos",
    version,
    text,
    "/repo/packages/app",
    "main",
    is_open
  )
}

def json_contains(text: String, needle: String): Bool = {
  if (needle.is_empty()) {
    return true
  }
  if (needle.len() > text.len()) {
    return false
  }

  var offset: usize = 0;
  while (offset + needle.len() <= text.len()) {
    if (text.slice(offset, offset + needle.len()) == needle) {
      return true
    }
    offset = offset + 1
  }
  false
}
