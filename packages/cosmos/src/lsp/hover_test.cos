import jsonrpc.core
import lsp.hover
import lsp.diagnostics
import lsp.lifecycle
import workspace.documents

def cosmos_test_hover_locals_fixture(): Bool = {
  val source = cosmos_hover_fixture_source();
  val hover = cosmos_hover_at(source, "local\n}");
  cosmos_hover_contains(hover, "val local: i32") and
    cosmos_hover_result_json(hover) == cosmos_hover_result_json(cosmos_hover_at(source, "local\n}"))
}

def cosmos_test_hover_functions_fixture(): Bool = {
  val source = cosmos_hover_fixture_source();
  val hover = cosmos_hover_at(source, "helper(widget");
  cosmos_hover_contains(hover, "def helper(value: i32): i32")
}

def cosmos_test_hover_members_fixture(): Bool = {
  val source = cosmos_hover_fixture_source();
  val method_hover = cosmos_hover_at(source, "get())");
  val field_hover = cosmos_hover_at(source, "value }");
  cosmos_hover_contains(method_hover, "def get(&self): i32") and
    cosmos_hover_contains(field_hover, "val value: i32")
}

def cosmos_test_hover_types_fixture(): Bool = {
  val source = cosmos_hover_fixture_source();
  val hover = cosmos_hover_at(source, "Widget =");
  cosmos_hover_contains(hover, "class Widget")
}

def cosmos_test_hover_unsupported_positions_are_empty(): Bool = {
  val source = cosmos_hover_fixture_source();
  val hover = cosmos_hover_at(source, " = ");
  cosmos_hover_result_json(hover) == "null"
}

def cosmos_test_hover_server_response_fixture(): Bool = {
  val source = cosmos_hover_fixture_source();
  val hover = cosmos_hover_at(source, "helper(widget");
  var server = lsp_server();
  server = cosmos_enable_hover(server);
  if (!server.capabilities.hover_provider) {
    return false
  }

  val request = JsonRpcRequest(jsonrpc_number_id("12"), "textDocument/hover", Option[JsonValue]::None);
  server = cosmos_lsp_hover_response(server, request, hover);
  server.has_request_handler("textDocument/hover") and
    server.outbound_len() == 1 and
    cosmos_hover_text_contains(server.session.outbound.get(0), "\"id\":12") and
    cosmos_hover_text_contains(server.session.outbound.get(0), "def helper(value: i32): i32")
}

def cosmos_hover_fixture_source(): String = {
  "class Widget {\n".concat(
    "  val value: i32\n".concat(
      "  def get(&self): i32 = { self.value }\n".concat(
        "}\n".concat(
          "def helper(value: i32): i32 = { value }\n".concat(
            "def main(): i32 = {\n".concat(
              "  val widget: Widget = Widget(1)\n".concat(
                "  val local: i32 = helper(widget.get())\n".concat(
                  "  local\n".concat(
                    "}"
                  )
                )
              )
            )
          )
        )
      )
    )
  )
}

def cosmos_hover_at(source: String, needle: String): Option[CosmosHover] = {
  val offset = cosmos_find_fixture_offset(source, needle);
  val position = cosmos_lsp_position(source, offset);
  cosmos_hover(cosmos_hover_snapshot(source), position.line, position.character)
}

def cosmos_hover_snapshot(source: String): CosmosTextDocumentSnapshot = {
  cosmos_text_document_snapshot(
    "file:///repo/packages/app/src/main.cos",
    "/repo/packages/app/src/main.cos",
    1,
    source,
    "/repo/packages/app",
    "main",
    true
  )
}

def cosmos_hover_contains(hover: Option[CosmosHover], needle: String): Bool = {
  hover match {
    case Option[CosmosHover]::Some(value) => {
      cosmos_hover_text_contains(value.contents, needle)
    }
    case Option[CosmosHover]::None => {
      false
    }
  }
}

def cosmos_hover_text_contains(text: String, needle: String): Bool = {
  if (needle.is_empty()) {
    return true
  }
  if (needle.len() > text.len()) {
    return false
  }

  var offset: usize = 0;
  while (offset + needle.len() <= text.len()) {
    if (text.slice(offset, offset + needle.len()) == needle) {
      return true
    }
    offset = offset + 1
  }
  false
}

def cosmos_find_fixture_offset(source: String, needle: String): usize = {
  if (needle.is_empty()) {
    return 0
  }
  var offset: usize = 0;
  while (offset + needle.len() <= source.len()) {
    if (source.slice(offset, offset + needle.len()) == needle) {
      return offset
    }
    offset = offset + 1
  }
  0
}
