class Path {
  val text: String
}

class IoError {
  val path: Path
  val message: String
}

class Fs {
  def read_to_string(&self, path: Path): Result[String, IoError] = {
    Result[String, IoError]::Ok(read_file(path.text))
  }
}

def core0_path_from_string(text: String): Path = {
  Path(text)
}

def core0_fs(): Fs = {
  Fs()
}
