class TextBuilder {
  var text: String

  def push(&mut self, value: String): Unit = {
    self.text = self.text.concat(value)
  }

  def push_line(&mut self, value: String): Unit = {
    self.push(value);
    self.push("\n")
  }

  def finish(&self): String = {
    self.text
  }
}

def core0_text_builder(): TextBuilder = {
  TextBuilder("")
}
