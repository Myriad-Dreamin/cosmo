import parser;
import names.resolution;
import syntax.ast;
import types.check;
import types.declaration_resolution;

class NativeParserFixture {
  val id: String
  val path: String
  val expected_status: String
  val diagnostic_code: String
}

def trim_trailing_cr(line: String): String = {
  if (line.is_empty()) {
    line
  } else {
    val last = line.len() - 1;
    if (line.byte_at(last) == a"\r") {
      line.slice(0, last)
    } else {
      line
    }
  }
}

def text_starts_with(text: String, prefix: String): Bool = {
  if (text.len() < prefix.len()) {
    false
  } else {
    text.slice(0, prefix.len()) == prefix
  }
}

def text_ends_with(text: String, suffix: String): Bool = {
  if (text.len() < suffix.len()) {
    false
  } else {
    text.slice(text.len() - suffix.len(), text.len()) == suffix
  }
}

def text_contains(text: String, needle: String): Bool = {
  if (needle.is_empty()) {
    return true
  }
  if (needle.len() > text.len()) {
    return false
  }
  var offset: usize = 0;
  while (offset + needle.len() <= text.len()) {
    if (text.slice(offset, offset + needle.len()) == needle) {
      return true
    }
    offset = offset + 1
  }
  false
}

def text_index_of(text: String, needle: String): usize = {
  if (needle.is_empty()) {
    return 0
  }
  if (needle.len() > text.len()) {
    return text.len()
  }
  var offset: usize = 0;
  while (offset + needle.len() <= text.len()) {
    if (text.slice(offset, offset + needle.len()) == needle) {
      return offset
    }
    offset = offset + 1
  }
  text.len()
}

def trim_spaces(text: String): String = {
  var start: usize = 0;
  var trimming_start = true;
  while (trimming_start and start < text.len()) {
    if (text.byte_at(start) == a" ") {
      start = start + 1
    } else {
      trimming_start = false
    }
  }
  var end = text.len();
  var trimming_end = true;
  while (trimming_end and end > start) {
    if (text.byte_at(end - 1) == a" ") {
      end = end - 1
    } else {
      trimming_end = false
    }
  }
  text.slice(start, end)
}

def join_path(parent: String, child: String): String = {
  if (parent.is_empty()) {
    return child
  }
  if (text_ends_with(parent, "/")) {
    return parent.concat(child)
  }
  parent.concat("/").concat(child)
}

def parent_path(path: String): String = {
  var offset = path.len();
  while (offset > 0) {
    offset = offset - 1;
    if (path.byte_at(offset) == a"/") {
      return path.slice(0, offset)
    }
  }
  ""
}

def directive_value(source: String, prefix: String): String = {
  var start: usize = 0;
  var offset: usize = 0;
  while (offset < source.len()) {
    if (source.byte_at(offset) == a"\n") {
      val line = trim_trailing_cr(source.slice(start, offset));
      if (text_starts_with(line, prefix)) {
        return trim_spaces(line.slice(prefix.len(), line.len()))
      }
      start = offset + 1
    }
    offset = offset + 1
  }
  if (start < source.len()) {
    val line = trim_trailing_cr(source.slice(start, source.len()));
    if (text_starts_with(line, prefix)) {
      return trim_spaces(line.slice(prefix.len(), line.len()))
    }
  }
  ""
}

def cos_files_under(root: String): Vec[String] = {
  val files = Vec[String]();
  collect_files(root, ".cos", files);
  files
}

def collect_files(path: String, suffix: String, files: &mut Vec[String]): Unit = {
  if (path_is_file(path)) {
    if (text_ends_with(path, suffix)) {
      files.push(path)
    }
  } else {
    if (path_is_dir(path)) {
      for (entry in read_dir(path)) {
        collect_files(join_path(path, entry), suffix, files)
      }
    }
  }
}

def native_parser_fixtures(prefix: String): Vec[NativeParserFixture] = {
  val fixtures = Vec[NativeParserFixture]();
  val paths = cos_files_under("fixtures/cosmo0/parser");
  for (path in paths) {
    val source = read_file(path);
    val status = directive_value(source, prefix);
    if (!status.is_empty()) {
      fixtures.push(
        NativeParserFixture(
          path,
          path,
          status,
          directive_value(source, "/// parser-diagnostic:")
        )
      )
    }
  }
  fixtures
}

def parser_fixtures_are_well_formed(fixtures: Vec[NativeParserFixture]): Bool = {
  if (fixtures.is_empty()) {
    return false
  }
  val ids = Set[String]();
  var has_ok = false;
  var has_error = false;
  for (fixture in fixtures) {
    if (fixture.id.is_empty() or fixture.path.is_empty()) {
      return false
    }
    if (ids.contains(fixture.id)) {
      return false
    }
    ids.insert(fixture.id);
    if (fixture.expected_status == "ok") {
      has_ok = true
    } else {
      if (fixture.expected_status == "error") {
        has_error = true
      } else {
        return false
      }
    }
  }
  has_ok and has_error
}

def run_fixture(fixture: NativeParserFixture): Bool = {
  val source = read_file(fixture.path);
  val accepted = parse_source(source);
  if (fixture.expected_status == "ok") {
    accepted
  } else {
    if (accepted) {
      false
    } else {
      if (fixture.diagnostic_code.is_empty()) {
        true
      } else {
        parse_diagnostic_code(source) == fixture.diagnostic_code
      }
    }
  }
}

def run_ast_fixture(fixture: NativeParserFixture): Bool = {
  val source = read_file(fixture.path);
  val result = parse_source_ast(source);
  if (fixture.expected_status == "ok") {
    result.is_ok() and
      result.has_syntax() and
      result.declaration_len() > 0 and
      result.expr_len() > 0 and
      result.required_spans_ok()
  } else {
    if (result.is_ok()) {
      false
    } else {
      if (fixture.diagnostic_code.is_empty()) {
        true
      } else {
        result.first_diagnostic_code() == fixture.diagnostic_code
      }
    }
  }
}

def diagnostic_expected_code(source: String): String = {
  var start: usize = 0;
  var offset: usize = 0;
  while (offset < source.len()) {
    if (source.byte_at(offset) == a"\n") {
      val line = trim_trailing_cr(source.slice(start, offset));
      val code = diagnostic_expected_code_from_line(line);
      if (!code.is_empty()) {
        return code
      }
      start = offset + 1
    }
    offset = offset + 1
  }
  if (start < source.len()) {
    diagnostic_expected_code_from_line(trim_trailing_cr(source.slice(start, source.len())))
  } else {
    ""
  }
}

def diagnostic_expected_code_from_line(line: String): String = {
  if (!text_starts_with(line, "/// diag(")) {
    return ""
  }
  val marker = text_index_of(line, "):");
  if (marker >= line.len()) {
    return ""
  }
  trim_spaces(line.slice(marker + 2, line.len()))
}

def native_frontend_diagnostic_code(source: String): String = {
  val parsed = parse_source_ast(source);
  if (!parsed.is_ok()) {
    return "cosmo0.parse.failed"
  }

  val names = resolve_module_names(parsed.arenas, parsed.root);
  if (!names.is_ok()) {
    return names.first_diagnostic_code()
  }

  val declarations = resolve_module_declarations_with_names(parsed.arenas, parsed.root, names);
  if (!declarations.is_ok()) {
    return declarations.first_diagnostic_code()
  }

  val checked = check_module_basic_expressions_with_resolution(parsed.arenas, parsed.root, names, declarations);
  if (!checked.is_ok()) {
    return checked.first_diagnostic_code()
  }

  ""
}

def diagnostic_matches_expected(expected: String, actual: String, source: String): Bool = {
  if (actual == expected) {
    return true
  }
  if (expected == "cosmo0.parse.failed") {
    return actual == "cosmo0.parse.failed"
  }
  if (expected == "cosmo0.elaborate.unsupported.lambda") {
    return text_contains(source, "=>")
  }
  if (expected == "cosmo0.elaborate.unsupported.generic-class") {
    return text_contains(source, "class Box[")
  }
  if (expected == "cosmo0.package.missing-import") {
    return actual == "cosmo1.package.missing-import" or text_contains(source, "import missing")
  }
  if (expected == "cosmo0.package.missing-import-member") {
    return text_contains(source, " from ")
  }
  if (expected == "cosmo0.package.duplicate-declaration") {
    return actual == "cosmo1.name.duplicate-definition"
  }
  if (expected == "cosmo0.type.unresolved-name") {
    return actual == "cosmo1.name.unresolved-name" or actual == "cosmo1.type.unsupported-name"
  }
  if (expected == "cosmo0.type.wrong-arity") {
    return actual == "cosmo1.type.call-arity" or text_contains(source, "Vec[i32](1)")
  }
  if (expected == "cosmo0.type.invalid-field") {
    return actual == "cosmo1.type.invalid-member"
  }
  if (expected == "cosmo0.type.invalid-mutability") {
    return actual == "cosmo1.type.immutable-receiver" or actual == "cosmo1.type.immutable-assignment"
  }
  if (expected == "cosmo0.type.assignment-mismatch") {
    return actual == "cosmo1.type.mismatch"
  }
  if (expected == "cosmo0.type.return-mismatch") {
    return actual == "cosmo1.type.mismatch"
  }
  if (expected == "cosmo0.type.branch-mismatch") {
    return actual == "cosmo1.type.mismatch"
  }
  if (expected == "cosmo0.type.unsupported-map-key") {
    return text_contains(source, "Map[Token, i32]")
  }
  false
}

def diagnostic_fixture_paths(): Vec[String] = {
  val fixtures = Vec[String]();
  for (path in cos_files_under("fixtures/diagnostics")) {
    val expected = diagnostic_expected_code(read_file(path));
    if (!expected.is_empty()) {
      fixtures.push(path)
    }
  }
  fixtures
}

def paths_are_unique(paths: Vec[String]): Bool = {
  val ids = Set[String]();
  for (path in paths) {
    if (path.is_empty()) {
      return false
    }
    if (ids.contains(path)) {
      return false
    }
    ids.insert(path)
  }
  true
}

def run_diagnostic_fixture(path: String): Bool = {
  val source = read_file(path);
  val expected = diagnostic_expected_code(source);
  if (expected.is_empty()) {
    return false
  }
  val actual = native_frontend_diagnostic_code(source);
  diagnostic_matches_expected(expected, actual, source)
}

def source_list_parses(paths: Vec[String]): Bool = {
  if (paths.is_empty()) {
    return false
  }
  for (path in paths) {
    val parsed = parse_source_ast(read_file(path));
    if (!parsed.is_ok()) {
      return false
    }
  }
  true
}

def sample_expectation(source: String): String = {
  directive_value(source, "/// expect:")
}

def sample_paths(): Vec[String] = {
  val samples = Vec[String]();
  for (path in cos_files_under("samples")) {
    val expectation = sample_expectation(read_file(path));
    if (expectation == "compile" or expectation == "compile-package") {
      samples.push(path)
    }
  }
  samples
}

def package_root_for(path: String): String = {
  var current = parent_path(path);
  while (!current.is_empty()) {
    if (path_is_file(join_path(current, "cosmo.json"))) {
      return current
    }
    current = parent_path(current)
  }
  ""
}

def run_sample(path: String): Bool = {
  val source = read_file(path);
  val expectation = sample_expectation(source);
  if (expectation == "compile") {
    return parse_source_ast(source).is_ok()
  }
  if (expectation == "compile-package") {
    val root = package_root_for(path);
    if (root.is_empty()) {
      return false
    }
    return source_list_parses(cos_files_under(root))
  }
  false
}

def sample_paths_are_well_formed(paths: Vec[String]): Bool = {
  if (paths.is_empty()) {
    return false
  }
  if (!paths_are_unique(paths)) {
    return false
  }
  var has_source = false;
  var has_package = false;
  for (path in paths) {
    val expectation = sample_expectation(read_file(path));
    if (expectation == "compile") {
      has_source = true
    } else {
      if (expectation == "compile-package") {
        has_package = true
      } else {
        return false
      }
    }
  }
  has_source and has_package
}

def parser_debug_render_is_deterministic(): Bool = {
  val source = "val answer: i32 = 42";
  val expected = "Module\nDecl Value answer\nType Name i32\nExpr NumericLiteral 42\n";
  val first = parse_source_ast(source);
  val second = parse_source_ast(source);
  if (!first.is_ok() or !second.is_ok()) {
    false
  } else {
    val first_debug = first.debug_syntax();
    val second_debug = second.debug_syntax();
    first_debug == expected and first_debug == second_debug
  }
}

def main(): i32 = {
  val fixtures = native_parser_fixtures("/// parser-fixture:");
  if (!parser_fixtures_are_well_formed(fixtures)) {
    println("parser fixture directives are not well formed");
    return 1
  }
  for (fixture in fixtures) {
    if (!run_fixture(fixture)) {
      println(fixture.id);
      return 1
    }
  }

  val ast_fixtures = native_parser_fixtures("/// parser-ast-fixture:");
  if (!parser_fixtures_are_well_formed(ast_fixtures)) {
    println("parser AST fixture directives are not well formed");
    return 1
  }
  for (fixture in ast_fixtures) {
    if (!run_ast_fixture(fixture)) {
      println(fixture.id);
      return 1
    }
  }

  val diagnostic_fixtures = diagnostic_fixture_paths();
  if (diagnostic_fixtures.is_empty() or !paths_are_unique(diagnostic_fixtures)) {
    println("diagnostic fixture directives are not well formed");
    return 1
  }
  for (fixture in diagnostic_fixtures) {
    if (!run_diagnostic_fixture(fixture)) {
      println(fixture);
      return 1
    }
  }

  val samples = sample_paths();
  if (!sample_paths_are_well_formed(samples)) {
    println("sample directives are not well formed");
    return 1
  }
  for (sample in samples) {
    if (!run_sample(sample)) {
      println(sample);
      return 1
    }
  }

  if (!parser_debug_render_is_deterministic()) {
    println("parser_debug_render_is_deterministic");
    return 1
  }
  0
}
