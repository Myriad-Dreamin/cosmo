import types.model

class IrDeclId {
  val value: String
}

class IrLocalId {
  val value: String
}

class IrBlockId {
  val value: String
}

class IrModule {
  val name: String
  val declarations: Vec[IrDeclaration]
}

class IrDeclaration {
  case Type(IrTypeDecl)
  case Function(IrFunction)
}

class IrTypeDecl {
  val id: IrDeclId
  val name: String
  val fields: Vec[IrField]
}

class IrField {
  val name: String
  val typ: TypeId
  val mutable: Bool
}

class IrFunction {
  val id: IrDeclId
  val name: String
  val params: Vec[IrParam]
  val return_type: TypeId
  val locals: Vec[IrLocal]
  val blocks: Vec[IrBlock]
  val owner: Option[IrDeclId]
  val receiver: Option[IrLocalId]
}

class IrParam {
  val id: IrLocalId
  val name: String
  val typ: TypeId
}

class IrLocal {
  val id: IrLocalId
  val name: String
  val typ: TypeId
  val mutable: Bool
}

class IrBlock {
  val id: IrBlockId
  val operations: Vec[IrOperation]
  val terminator: IrTerminator
}

class IrFunctionSignature {
  val params: Vec[TypeId]
  val return_type: TypeId
}

class IrValue {
  case Unit(TypeId)
  case BoolLiteral(Bool, TypeId)
  case StringLiteral(String, TypeId)
  case NumericLiteral(String, TypeId)
  case Local(IrLocalId, TypeId)
  case Function(IrDeclId, IrFunctionSignature)
}

class IrOperation {
  case InitLocal(IrLocalId, IrValue)
  case Assign(IrLocalId, IrValue)
  case ConstructType(IrLocalId, TypeId, Vec[IrFieldInit])
  case DirectCall(Option[IrLocalId], IrDeclId, Vec[IrValue], IrFunctionSignature)
  case IntrinsicCall(Option[IrLocalId], String, Vec[IrValue], IrFunctionSignature)
  case FieldGet(IrLocalId, IrValue, String, TypeId)
  case FieldSet(IrValue, String, IrValue)
  case Binary(IrLocalId, String, IrValue, IrValue, TypeId)
}

class IrFieldInit {
  val name: String
  val value: IrValue
}

class IrTerminator {
  case Return(Option[IrValue])
  case Branch(IrBlockId)
  case CondBranch(IrValue, IrBlockId, IrBlockId)
  case Unreachable(String)
}

class IrDiagnostic {
  val code: String
  val message: String
}

class IrVerifyResult {
  val diagnostics: Vec[IrDiagnostic]

  def is_ok(&self): Bool = {
    self.diagnostics.is_empty()
  }

  def first_code(&self): String = {
    if (self.diagnostics.is_empty()) {
      return ""
    }
    self.diagnostics.get(0).code
  }
}

class IrFunctionEnv {
  val defined: Vec[IrLocalId]
}

def ir_decl_id(value: String): IrDeclId = {
  IrDeclId(value)
}

def ir_local_id(value: String): IrLocalId = {
  IrLocalId(value)
}

def ir_block_id(value: String): IrBlockId = {
  IrBlockId(value)
}

def ir_signature(params: Vec[TypeId], return_type: TypeId): IrFunctionSignature = {
  IrFunctionSignature(params, return_type)
}

def ir_value_type(value: IrValue): TypeId = {
  value match {
    case IrValue.Unit(typ) => {
      typ
    }
    case IrValue.BoolLiteral(value, typ) => {
      typ
    }
    case IrValue.StringLiteral(value, typ) => {
      typ
    }
    case IrValue.NumericLiteral(value, typ) => {
      typ
    }
    case IrValue.Local(id, typ) => {
      typ
    }
    case IrValue.Function(id, signature) => {
      signature.return_type
    }
  }
}

def verify_ir_module(types: TypeStore, ir_module: IrModule): IrVerifyResult = {
  val diagnostics = Vec[IrDiagnostic]();
  verify_duplicate_declarations(ir_module, diagnostics);
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Type(type_decl) => {
        verify_ir_type(type_decl, diagnostics)
      }
      case IrDeclaration.Function(fn_value) => {
        verify_ir_function(types, ir_module, fn_value, diagnostics)
      }
    }
  }
  IrVerifyResult(diagnostics)
}

def verify_duplicate_declarations(ir_module: IrModule, diagnostics: Vec[IrDiagnostic]): Unit = {
  var index: usize = 0;
  while (index < ir_module.declarations.len()) {
    val current = declaration_id(ir_module.declarations.get(index));
    var next = index + 1;
    while (next < ir_module.declarations.len()) {
      val other = declaration_id(ir_module.declarations.get(next));
      if (current.value == other.value) {
        ir_error(diagnostics, "cosmo1.ir.duplicate-declaration", "duplicate declaration ".concat(current.value))
      }
      next = next + 1
    }
    index = index + 1
  }
}

def declaration_id(declaration: IrDeclaration): IrDeclId = {
  declaration match {
    case IrDeclaration.Type(type_decl) => {
      type_decl.id
    }
    case IrDeclaration.Function(fn_value) => {
      fn_value.id
    }
  }
}

def verify_ir_type(type_decl: IrTypeDecl, diagnostics: Vec[IrDiagnostic]): Unit = {
  var index: usize = 0;
  while (index < type_decl.fields.len()) {
    val current = type_decl.fields.get(index).name;
    var next = index + 1;
    while (next < type_decl.fields.len()) {
      val other = type_decl.fields.get(next).name;
      if (current == other) {
        ir_error(diagnostics, "cosmo1.ir.duplicate-field", "duplicate field ".concat(current))
      }
      next = next + 1
    }
    index = index + 1
  }
}

def verify_ir_function(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  if (fn_value.blocks.is_empty()) {
    ir_error(diagnostics, "cosmo1.ir.missing-block", "fn_value ".concat(fn_value.id.value).concat(" has no blocks"));
  } else {
    verify_duplicate_params(fn_value, diagnostics);
    verify_duplicate_locals(fn_value, diagnostics);
    verify_duplicate_blocks(fn_value, diagnostics);
    verify_branch_targets(fn_value, diagnostics);

    for (block in fn_value.blocks) {
      verify_ir_block(types, ir_module, fn_value, block, diagnostics)
    }
  }
}

def verify_duplicate_params(fn_value: IrFunction, diagnostics: Vec[IrDiagnostic]): Unit = {
  var index: usize = 0;
  while (index < fn_value.params.len()) {
    val current = fn_value.params.get(index).id;
    var next = index + 1;
    while (next < fn_value.params.len()) {
      val other = fn_value.params.get(next).id;
      if (current.value == other.value) {
        ir_error(diagnostics, "cosmo1.ir.duplicate-local", "duplicate parameter ".concat(current.value))
      }
      next = next + 1
    }
    index = index + 1
  }
}

def verify_duplicate_locals(fn_value: IrFunction, diagnostics: Vec[IrDiagnostic]): Unit = {
  var index: usize = 0;
  while (index < fn_value.locals.len()) {
    val current = fn_value.locals.get(index).id;
    if (function_has_param(fn_value, current)) {
      ir_error(diagnostics, "cosmo1.ir.duplicate-local", "local duplicates parameter ".concat(current.value))
    }
    var next = index + 1;
    while (next < fn_value.locals.len()) {
      val other = fn_value.locals.get(next).id;
      if (current.value == other.value) {
        ir_error(diagnostics, "cosmo1.ir.duplicate-local", "duplicate local ".concat(current.value))
      }
      next = next + 1
    }
    index = index + 1
  }
}

def verify_duplicate_blocks(fn_value: IrFunction, diagnostics: Vec[IrDiagnostic]): Unit = {
  var index: usize = 0;
  while (index < fn_value.blocks.len()) {
    val current = fn_value.blocks.get(index).id;
    var next = index + 1;
    while (next < fn_value.blocks.len()) {
      val other = fn_value.blocks.get(next).id;
      if (current.value == other.value) {
        ir_error(diagnostics, "cosmo1.ir.duplicate-block", "duplicate block ".concat(current.value))
      }
      next = next + 1
    }
    index = index + 1
  }
}

def verify_branch_targets(fn_value: IrFunction, diagnostics: Vec[IrDiagnostic]): Unit = {
  for (block in fn_value.blocks) {
    block.terminator match {
      case IrTerminator.Return(value) => {
      }
      case IrTerminator.Branch(target) => {
        verify_block_target(fn_value, target, diagnostics)
      }
      case IrTerminator.CondBranch(condition, true_target, false_target) => {
        verify_block_target(fn_value, true_target, diagnostics);
        verify_block_target(fn_value, false_target, diagnostics)
      }
      case IrTerminator.Unreachable(reason) => {
      }
    }
  }
}

def verify_block_target(fn_value: IrFunction, target: IrBlockId, diagnostics: Vec[IrDiagnostic]): Unit = {
  if (!function_has_block(fn_value, target)) {
    ir_error(diagnostics, "cosmo1.ir.invalid-branch", "missing block ".concat(target.value))
  }
}

def verify_ir_block(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  block: IrBlock,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  val env = initial_function_env(fn_value);
  define_function_operation_outputs(fn_value, env);
  for (operation in block.operations) {
    verify_ir_operation(types, ir_module, fn_value, env, operation, diagnostics)
  }
  verify_ir_terminator(types, fn_value, env, block.terminator, diagnostics)
}

def initial_function_env(fn_value: IrFunction): IrFunctionEnv = {
  val defined = Vec[IrLocalId]();
  for (param in fn_value.params) {
    defined.push(param.id)
  }
  IrFunctionEnv(defined)
}

def define_function_operation_outputs(fn_value: IrFunction, env: IrFunctionEnv): Unit = {
  for (block in fn_value.blocks) {
    for (operation in block.operations) {
      define_operation_output(operation, env)
    }
  }
}

def define_operation_output(operation: IrOperation, env: IrFunctionEnv): Unit = {
  operation match {
    case IrOperation.InitLocal(target, value) => {
      define_local(env, target)
    }
    case IrOperation.Assign(target, value) => {
      define_local(env, target)
    }
    case IrOperation.ConstructType(output, owner, fields) => {
      define_local(env, output)
    }
    case IrOperation.DirectCall(output, callee, args, signature) => {
      define_optional_local(env, output)
    }
    case IrOperation.IntrinsicCall(output, name, args, signature) => {
      define_optional_local(env, output)
    }
    case IrOperation.FieldGet(output, receiver, field, result_type) => {
      define_local(env, output)
    }
    case IrOperation.FieldSet(receiver, field, value) => {
    }
    case IrOperation.Binary(output, op, left, right, result_type) => {
      define_local(env, output)
    }
  }
}

def define_optional_local(env: IrFunctionEnv, output: Option[IrLocalId]): Unit = {
  output match {
    case Option[IrLocalId]::Some(target) => {
      define_local(env, target)
    }
    case Option[IrLocalId]::None => {
    }
  }
}

def verify_ir_operation(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  operation: IrOperation,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  operation match {
    case IrOperation.InitLocal(target, value) => {
      verify_value(types, fn_value, env, value, diagnostics);
      verify_defined_local_type(types, fn_value, target, ir_value_type(value), diagnostics);
      define_local(env, target)
    }
    case IrOperation.Assign(target, value) => {
      verify_value(types, fn_value, env, value, diagnostics);
      verify_defined_local_type(types, fn_value, target, ir_value_type(value), diagnostics);
      define_local(env, target)
    }
    case IrOperation.ConstructType(output, owner, fields) => {
      verify_construct_type(types, ir_module, fn_value, env, output, owner, fields, diagnostics)
    }
    case IrOperation.DirectCall(output, callee, args, signature) => {
      verify_call(types, ir_module, fn_value, env, output, callee, args, signature, diagnostics)
    }
    case IrOperation.IntrinsicCall(output, name, args, signature) => {
      verify_intrinsic_call(types, fn_value, env, output, name, args, signature, diagnostics)
    }
    case IrOperation.FieldGet(output, receiver, field, result_type) => {
      verify_field_get(types, ir_module, fn_value, env, output, receiver, field, result_type, diagnostics)
    }
    case IrOperation.FieldSet(receiver, field, value) => {
      verify_field_set(types, ir_module, fn_value, env, receiver, field, value, diagnostics)
    }
    case IrOperation.Binary(output, op, left, right, result_type) => {
      verify_binary(types, fn_value, env, output, op, left, right, result_type, diagnostics)
    }
  }
}

def verify_construct_type(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  output: IrLocalId,
  owner: TypeId,
  fields: Vec[IrFieldInit],
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  var index: usize = 0;
  while (index < fields.len()) {
    val init = fields.get(index);
    verify_value(types, fn_value, env, init.value, diagnostics);
    val maybe_field = find_ir_field(types, ir_module, owner, init.name);
    maybe_field match {
      case Option[IrField]::Some(field_value) => {
        if (!ir_type_equals(types, field_value.typ, ir_value_type(init.value))) {
          ir_error(diagnostics, "cosmo1.ir.invalid-construct", "constructor field type mismatch for ".concat(init.name))
        }
      }
      case Option[IrField]::None => {
        ir_error(diagnostics, "cosmo1.ir.invalid-construct", "unknown constructor field ".concat(init.name))
      }
    }
    index = index + 1
  }
  verify_defined_local_type(types, fn_value, output, owner, diagnostics);
  define_local(env, output)
}

def verify_field_get(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  output: IrLocalId,
  receiver: IrValue,
  field: String,
  result_type: TypeId,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  verify_value(types, fn_value, env, receiver, diagnostics);
  val maybe_field = find_ir_field(types, ir_module, ir_value_type(receiver), field);
  maybe_field match {
    case Option[IrField]::Some(field_value) => {
      if (!ir_type_equals(types, field_value.typ, result_type)) {
        ir_error(diagnostics, "cosmo1.ir.invalid-field", "field get result type mismatch for ".concat(field))
      }
    }
    case Option[IrField]::None => {
      ir_error(diagnostics, "cosmo1.ir.invalid-field", "unknown field ".concat(field))
    }
  }
  verify_defined_local_type(types, fn_value, output, result_type, diagnostics);
  define_local(env, output)
}

def verify_field_set(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  receiver: IrValue,
  field: String,
  value: IrValue,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  verify_value(types, fn_value, env, receiver, diagnostics);
  verify_value(types, fn_value, env, value, diagnostics);
  val maybe_field = find_ir_field(types, ir_module, ir_value_type(receiver), field);
  maybe_field match {
    case Option[IrField]::Some(field_value) => {
      if (!field_value.mutable) {
        ir_error(diagnostics, "cosmo1.ir.invalid-field", "field is immutable ".concat(field))
      }
      if (!ir_type_equals(types, field_value.typ, ir_value_type(value))) {
        ir_error(diagnostics, "cosmo1.ir.invalid-field", "field set value type mismatch for ".concat(field))
      }
    }
    case Option[IrField]::None => {
      ir_error(diagnostics, "cosmo1.ir.invalid-field", "unknown field ".concat(field))
    }
  }
}

def verify_binary(
  types: TypeStore,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  output: IrLocalId,
  op: String,
  left: IrValue,
  right: IrValue,
  result_type: TypeId,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  verify_value(types, fn_value, env, left, diagnostics);
  verify_value(types, fn_value, env, right, diagnostics);
  if (!ir_type_equals(types, ir_value_type(left), ir_value_type(right))) {
    ir_error(diagnostics, "cosmo1.ir.invalid-binary", "binary operand type mismatch for ".concat(op))
  }
  if (!ir_binary_result_matches(types, op, ir_value_type(left), result_type)) {
    ir_error(diagnostics, "cosmo1.ir.invalid-binary", "binary result type mismatch for ".concat(op))
  }
  verify_defined_local_type(types, fn_value, output, result_type, diagnostics);
  define_local(env, output)
}

def verify_call(
  types: TypeStore,
  ir_module: IrModule,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  output: Option[IrLocalId],
  callee: IrDeclId,
  args: Vec[IrValue],
  signature: IrFunctionSignature,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  verify_function_callee(ir_module, callee, signature, diagnostics);
  if (args.len() != signature.params.len()) {
    ir_error(diagnostics, "cosmo1.ir.invalid-call", "call arity mismatch for ".concat(callee.value))
  }

  var index: usize = 0;
  while (index < args.len() and index < signature.params.len()) {
    val arg = args.get(index);
    verify_value(types, fn_value, env, arg, diagnostics);
    if (!ir_type_equals(types, ir_value_type(arg), signature.params.get(index))) {
      ir_error(diagnostics, "cosmo1.ir.invalid-call", "call argument type mismatch for ".concat(callee.value))
    }
    index = index + 1
  }

  output match {
    case Option[IrLocalId]::Some(target) => {
      verify_defined_local_type(types, fn_value, target, signature.return_type, diagnostics);
      define_local(env, target)
    }
    case Option[IrLocalId]::None => {
      if (!is_unit_type(types, signature.return_type)) {
        ir_error(diagnostics, "cosmo1.ir.invalid-call", "non-unit call result is not captured for ".concat(callee.value))
      }
    }
  }
}

def verify_intrinsic_call(
  types: TypeStore,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  output: Option[IrLocalId],
  name: String,
  args: Vec[IrValue],
  signature: IrFunctionSignature,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  if (!ir_intrinsic_is_known(name)) {
    ir_error(diagnostics, "cosmo1.ir.invalid-intrinsic", "unknown intrinsic ".concat(name))
  }
  if (args.len() != signature.params.len()) {
    ir_error(diagnostics, "cosmo1.ir.invalid-intrinsic", "intrinsic arity mismatch for ".concat(name))
  }

  var index: usize = 0;
  while (index < args.len() and index < signature.params.len()) {
    val arg = args.get(index);
    verify_value(types, fn_value, env, arg, diagnostics);
    if (!ir_type_equals(types, ir_value_type(arg), signature.params.get(index))) {
      ir_error(diagnostics, "cosmo1.ir.invalid-intrinsic", "intrinsic argument type mismatch for ".concat(name))
    }
    index = index + 1
  }

  output match {
    case Option[IrLocalId]::Some(target) => {
      verify_defined_local_type(types, fn_value, target, signature.return_type, diagnostics);
      define_local(env, target)
    }
    case Option[IrLocalId]::None => {
      if (!is_unit_type(types, signature.return_type)) {
        ir_error(diagnostics, "cosmo1.ir.invalid-intrinsic", "non-unit intrinsic result is not captured for ".concat(name))
      }
    }
  }
}

def ir_intrinsic_is_known(name: String): Bool = {
  name == "string.len" or
    name == "string.size" or
    name == "string.byte_at" or
    name == "string.slice" or
    name == "string.concat" or
    name == "string.is_empty"
}

def verify_function_callee(
  ir_module: IrModule,
  callee: IrDeclId,
  signature: IrFunctionSignature,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  val maybe_function = find_function(ir_module, callee);
  maybe_function match {
    case Option[IrFunction]::Some(fn_value) => {
      if (fn_value.params.len() != signature.params.len()) {
        ir_error(diagnostics, "cosmo1.ir.invalid-call", "callee signature arity mismatch for ".concat(callee.value))
      }
    }
    case Option[IrFunction]::None => {
      ir_error(diagnostics, "cosmo1.ir.invalid-call", "unknown callee ".concat(callee.value))
    }
  }
}

def verify_ir_terminator(
  types: TypeStore,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  terminator: IrTerminator,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  terminator match {
    case IrTerminator.Return(value) => {
      verify_return(types, fn_value, env, value, diagnostics)
    }
    case IrTerminator.Branch(target) => {
    }
    case IrTerminator.CondBranch(condition, true_target, false_target) => {
      verify_value(types, fn_value, env, condition, diagnostics);
      if (ir_type_display(types, ir_value_type(condition)) != "Bool") {
        ir_error(diagnostics, "cosmo1.ir.invalid-branch", "conditional branch requires Bool")
      }
    }
    case IrTerminator.Unreachable(reason) => {
    }
  }
}

def verify_return(
  types: TypeStore,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  value: Option[IrValue],
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  value match {
    case Option[IrValue]::Some(actual) => {
      verify_value(types, fn_value, env, actual, diagnostics);
      if (!ir_type_equals(types, fn_value.return_type, ir_value_type(actual))) {
        ir_error(diagnostics, "cosmo1.ir.invalid-return", "return type mismatch in ".concat(fn_value.id.value))
      }
    }
    case Option[IrValue]::None => {
      if (!is_unit_type(types, fn_value.return_type)) {
        ir_error(diagnostics, "cosmo1.ir.invalid-return", "missing return value in ".concat(fn_value.id.value))
      }
    }
  }
}

def verify_value(
  types: TypeStore,
  fn_value: IrFunction,
  env: IrFunctionEnv,
  value: IrValue,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  value match {
    case IrValue.Unit(typ) => {
    }
    case IrValue.BoolLiteral(value, typ) => {
    }
    case IrValue.StringLiteral(value, typ) => {
    }
    case IrValue.NumericLiteral(value, typ) => {
    }
    case IrValue.Local(id, typ) => {
      if (!function_has_local_or_param(fn_value, id)) {
        ir_error(diagnostics, "cosmo1.ir.unknown-local", "unknown local ".concat(id.value));
      }
      if (!local_is_defined(env, id)) {
        ir_error(diagnostics, "cosmo1.ir.use-before-definition", "local used before definition ".concat(id.value))
      }
      verify_defined_local_type(types, fn_value, id, typ, diagnostics)
    }
    case IrValue.Function(id, signature) => {
    }
  }
}

def verify_defined_local_type(
  types: TypeStore,
  fn_value: IrFunction,
  id: IrLocalId,
  actual: TypeId,
  diagnostics: Vec[IrDiagnostic]
): Unit = {
  val maybe_expected = find_local_type(fn_value, id);
  maybe_expected match {
    case Option[TypeId]::Some(expected) => {
      if (!ir_type_equals(types, expected, actual)) {
        ir_error(diagnostics, "cosmo1.ir.local-type-mismatch", "local type mismatch for ".concat(id.value))
      }
    }
    case Option[TypeId]::None => {
      ir_error(diagnostics, "cosmo1.ir.unknown-local", "unknown local ".concat(id.value))
    }
  }
}

def find_function(ir_module: IrModule, id: IrDeclId): Option[IrFunction] = {
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Function(fn_value) => {
        if (fn_value.id.value == id.value) {
          return Option[IrFunction]::Some(fn_value)
        }
      }
      case IrDeclaration.Type(type_decl) => {
      }
    }
  }
  Option[IrFunction]::None
}

def find_ir_field(types: TypeStore, ir_module: IrModule, receiver_type: TypeId, name: String): Option[IrField] = {
  val receiver_name = ir_receiver_type_name(types, receiver_type);
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Type(type_decl) => {
        if (type_decl.name == receiver_name) {
          return find_type_field(type_decl, name)
        }
      }
      case IrDeclaration.Function(fn_value) => {
      }
    }
  }
  Option[IrField]::None
}

def find_type_field(type_decl: IrTypeDecl, name: String): Option[IrField] = {
  for (field in type_decl.fields) {
    if (field.name == name) {
      return Option[IrField]::Some(field)
    }
  }
  Option[IrField]::None
}

def ir_receiver_type_name(types: TypeStore, id: TypeId): String = {
  val value = types.type_value(id);
  value match {
    case CosmoType.User(name) => {
      name
    }
    case CosmoType.Reference(mutable, inner) => {
      ir_receiver_type_name(types, inner)
    }
    case CosmoType.Primitive(name) => {
      name
    }
    case CosmoType.Function(params, return_type) => {
      ""
    }
    case CosmoType.Never => {
      ""
    }
    case CosmoType.Error => {
      ""
    }
  }
}

def find_local_type(fn_value: IrFunction, id: IrLocalId): Option[TypeId] = {
  for (param in fn_value.params) {
    if (param.id.value == id.value) {
      return Option[TypeId]::Some(param.typ)
    }
  }
  for (local in fn_value.locals) {
    if (local.id.value == id.value) {
      return Option[TypeId]::Some(local.typ)
    }
  }
  Option[TypeId]::None
}

def function_has_param(fn_value: IrFunction, id: IrLocalId): Bool = {
  for (param in fn_value.params) {
    if (param.id.value == id.value) {
      return true
    }
  }
  false
}

def function_has_local_or_param(fn_value: IrFunction, id: IrLocalId): Bool = {
  val local_type = find_local_type(fn_value, id);
  local_type match {
    case Option[TypeId]::Some(value) => {
      true
    }
    case Option[TypeId]::None => {
      false
    }
  }
}

def function_has_block(fn_value: IrFunction, id: IrBlockId): Bool = {
  for (block in fn_value.blocks) {
    if (block.id.value == id.value) {
      return true
    }
  }
  false
}

def local_is_defined(env: IrFunctionEnv, id: IrLocalId): Bool = {
  for (defined_id in env.defined) {
    if (defined_id.value == id.value) {
      return true
    }
  }
  false
}

def define_local(env: IrFunctionEnv, id: IrLocalId): Unit = {
  if (!local_is_defined(env, id)) {
    env.defined.push(id)
  }
}

def is_unit_type(types: TypeStore, id: TypeId): Bool = {
  ir_type_display(types, id) == "Unit"
}

def ir_binary_result_matches(types: TypeStore, op: String, operand_type: TypeId, result_type: TypeId): Bool = {
  if (ir_binary_is_arithmetic(op)) {
    return ir_type_equals(types, operand_type, result_type)
  }
  if (ir_binary_is_comparison(op) or ir_binary_is_equality(op)) {
    return ir_type_display(types, result_type) == "Bool"
  }
  if (ir_binary_is_bool(op)) {
    return ir_type_display(types, operand_type) == "Bool" and ir_type_display(types, result_type) == "Bool"
  }
  false
}

def ir_binary_is_arithmetic(op: String): Bool = {
  op == "+" or op == "-" or op == "*" or op == "/" or op == "%"
}

def ir_binary_is_comparison(op: String): Bool = {
  op == "<" or op == "<=" or op == ">" or op == ">="
}

def ir_binary_is_equality(op: String): Bool = {
  op == "==" or op == "!="
}

def ir_binary_is_bool(op: String): Bool = {
  op == "and" or op == "or"
}

def ir_error(diagnostics: Vec[IrDiagnostic], code: String, message: String): Unit = {
  diagnostics.push(IrDiagnostic(code, message))
}

def ir_type_equals(types: TypeStore, left: TypeId, right: TypeId): Bool = {
  ir_type_display(types, left) == ir_type_display(types, right)
}

def ir_type_display(types: TypeStore, id: TypeId): String = {
  ir_type_node_display(types, types.type_value(id))
}

def ir_type_node_display(types: TypeStore, value: CosmoType): String = {
  value match {
    case CosmoType.Primitive(name) => {
      name
    }
    case CosmoType.User(name) => {
      name
    }
    case CosmoType.Function(params, return_type) => {
      "fn(".concat(ir_type_display_list(types, params)).concat(") -> ").concat(ir_type_display(types, return_type))
    }
    case CosmoType.Reference(mutable, inner) => {
      if (mutable) {
        "&mut ".concat(ir_type_display(types, inner))
      } else {
        "&".concat(ir_type_display(types, inner))
      }
    }
    case CosmoType.Never => {
      "never"
    }
    case CosmoType.Error => {
      "<error>"
    }
  }
}

def ir_type_display_list(types: TypeStore, items: Vec[TypeId]): String = {
  var text = "";
  var index: usize = 0;
  while (index < items.len()) {
    if (index > 0) {
      text = text.concat(", ")
    }
    text = text.concat(ir_type_display(types, items.get(index)));
    index = index + 1
  }
  text
}

def render_ir_module(types: TypeStore, ir_module: IrModule): String = {
  var text = "module ".concat(ir_module.name).concat(" {\n");
  for (declaration in ir_module.declarations) {
    text = text.concat(render_ir_declaration(types, declaration)).concat("\n")
  }
  text.concat("}")
}

def render_ir_declaration(types: TypeStore, declaration: IrDeclaration): String = {
  declaration match {
    case IrDeclaration.Type(type_decl) => {
      render_ir_type(types, type_decl)
    }
    case IrDeclaration.Function(fn_value) => {
      render_ir_function(types, fn_value)
    }
  }
}

def render_ir_type(types: TypeStore, type_decl: IrTypeDecl): String = {
  var text = "  type @".concat(type_decl.id.value).concat(" ").concat(type_decl.name).concat(" {\n");
  for (field in type_decl.fields) {
    text = text.concat("    field ");
    if (field.mutable) {
      text = text.concat("var ")
    }
    text = text.concat(field.name).concat(": ").concat(ir_type_display(types, field.typ)).concat("\n")
  }
  text.concat("  }")
}

def render_ir_function(types: TypeStore, fn_value: IrFunction): String = {
  var text = "  fn @".concat(fn_value.id.value).concat(" ").concat(fn_value.name).concat("(");
  text = text.concat(render_ir_params(types, fn_value.params));
  text = text.concat(") -> ").concat(ir_type_display(types, fn_value.return_type));
  fn_value.owner match {
    case Option[IrDeclId]::Some(owner) => {
      text = text.concat(" owner @").concat(owner.value)
    }
    case Option[IrDeclId]::None => {
    }
  }
  fn_value.receiver match {
    case Option[IrLocalId]::Some(receiver) => {
      text = text.concat(" receiver %").concat(receiver.value)
    }
    case Option[IrLocalId]::None => {
    }
  }
  text = text.concat(" {\n");
  for (local in fn_value.locals) {
    text = text.concat("    local %").concat(local.id.value).concat(" ").concat(local.name).concat(": ");
    text = text.concat(ir_type_display(types, local.typ));
    if (local.mutable) {
      text = text.concat(" mut")
    }
    text = text.concat("\n")
  }
  for (block in fn_value.blocks) {
    text = text.concat(render_ir_block(types, block))
  }
  text.concat("  }")
}

def render_ir_params(types: TypeStore, params: Vec[IrParam]): String = {
  var text = "";
  var index: usize = 0;
  while (index < params.len()) {
    val param = params.get(index);
    if (index > 0) {
      text = text.concat(", ")
    }
    text = text.concat("%").concat(param.id.value).concat(" ").concat(param.name).concat(": ");
    text = text.concat(ir_type_display(types, param.typ));
    index = index + 1
  }
  text
}

def render_ir_block(types: TypeStore, block: IrBlock): String = {
  var text = "    ^".concat(block.id.value).concat(":\n");
  for (operation in block.operations) {
    text = text.concat("      ").concat(render_ir_operation(types, operation)).concat("\n")
  }
  text.concat("      ").concat(render_ir_terminator(types, block.terminator)).concat("\n")
}

def render_ir_operation(types: TypeStore, operation: IrOperation): String = {
  operation match {
    case IrOperation.InitLocal(target, value) => {
      "%".concat(target.value).concat(" = init ").concat(render_ir_value(types, value))
    }
    case IrOperation.Assign(target, value) => {
      "assign %".concat(target.value).concat(" = ").concat(render_ir_value(types, value))
    }
    case IrOperation.DirectCall(output, callee, args, signature) => {
      render_ir_call(types, output, callee, args, signature)
    }
    case IrOperation.ConstructType(output, owner, fields) => {
      render_ir_construct_type(types, output, owner, fields)
    }
    case IrOperation.IntrinsicCall(output, name, args, signature) => {
      render_ir_intrinsic_call(types, output, name, args, signature)
    }
    case IrOperation.FieldGet(output, receiver, field, result_type) => {
      "%".concat(output.value)
        .concat(" = field_get ")
        .concat(render_ir_value(types, receiver))
        .concat(".")
        .concat(field)
        .concat(" -> ")
        .concat(ir_type_display(types, result_type))
    }
    case IrOperation.FieldSet(receiver, field, value) => {
      "field_set "
        .concat(render_ir_value(types, receiver))
        .concat(".")
        .concat(field)
        .concat(" = ")
        .concat(render_ir_value(types, value))
    }
    case IrOperation.Binary(output, op, left, right, result_type) => {
      "%".concat(output.value)
        .concat(" = ")
        .concat(render_ir_value(types, left))
        .concat(" ")
        .concat(op)
        .concat(" ")
        .concat(render_ir_value(types, right))
        .concat(" -> ")
        .concat(ir_type_display(types, result_type))
    }
  }
}

def render_ir_construct_type(types: TypeStore, output: IrLocalId, owner: TypeId, fields: Vec[IrFieldInit]): String = {
  var text = "%".concat(output.value).concat(" = construct ").concat(ir_type_display(types, owner)).concat("(");
  var index: usize = 0;
  while (index < fields.len()) {
    if (index > 0) {
      text = text.concat(", ")
    }
    val field = fields.get(index);
    text = text.concat(field.name).concat(" = ").concat(render_ir_value(types, field.value));
    index = index + 1
  }
  text.concat(")")
}

def render_ir_intrinsic_call(
  types: TypeStore,
  output: Option[IrLocalId],
  name: String,
  args: Vec[IrValue],
  signature: IrFunctionSignature
): String = {
  var text = "";
  output match {
    case Option[IrLocalId]::Some(target) => {
      text = text.concat("%").concat(target.value).concat(" = ")
    }
    case Option[IrLocalId]::None => {
    }
  }
  text = text.concat("intrinsic @").concat(name).concat("(");
  text = text.concat(render_ir_args(types, args)).concat(") -> ");
  text.concat(ir_type_display(types, signature.return_type))
}

def render_ir_call(
  types: TypeStore,
  output: Option[IrLocalId],
  callee: IrDeclId,
  args: Vec[IrValue],
  signature: IrFunctionSignature
): String = {
  var text = "";
  output match {
    case Option[IrLocalId]::Some(target) => {
      text = text.concat("%").concat(target.value).concat(" = ")
    }
    case Option[IrLocalId]::None => {
    }
  }
  text = text.concat("call @").concat(callee.value).concat("(");
  text = text.concat(render_ir_args(types, args)).concat(") -> ");
  text.concat(ir_type_display(types, signature.return_type))
}

def render_ir_terminator(types: TypeStore, terminator: IrTerminator): String = {
  terminator match {
    case IrTerminator.Return(value) => {
      value match {
        case Option[IrValue]::Some(actual) => {
          "return ".concat(render_ir_value(types, actual))
        }
        case Option[IrValue]::None => {
          "return"
        }
      }
    }
    case IrTerminator.Branch(target) => {
      "branch ^".concat(target.value)
    }
    case IrTerminator.CondBranch(condition, true_target, false_target) => {
      "cond_branch ".concat(render_ir_value(types, condition)).concat(" ? ^").concat(true_target.value).concat(" : ^").concat(false_target.value)
    }
    case IrTerminator.Unreachable(reason) => {
      "unreachable ".concat(reason)
    }
  }
}

def render_ir_args(types: TypeStore, args: Vec[IrValue]): String = {
  var text = "";
  var index: usize = 0;
  while (index < args.len()) {
    if (index > 0) {
      text = text.concat(", ")
    }
    text = text.concat(render_ir_value(types, args.get(index)));
    index = index + 1
  }
  text
}

def render_ir_value(types: TypeStore, value: IrValue): String = {
  value match {
    case IrValue.Unit(typ) => {
      "()"
    }
    case IrValue.BoolLiteral(value, typ) => {
      if (value) {
        "true"
      } else {
        "false"
      }
    }
    case IrValue.StringLiteral(value, typ) => {
      "\"".concat(value).concat("\"")
    }
    case IrValue.NumericLiteral(value, typ) => {
      value.concat(":").concat(ir_type_display(types, typ))
    }
    case IrValue.Local(id, typ) => {
      "%".concat(id.value)
    }
    case IrValue.Function(id, signature) => {
      "fn @".concat(id.value)
    }
  }
}
