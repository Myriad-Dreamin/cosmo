def declaration_fixture_has_parser_state(types: TypeStore, ir_module: IrModule): Bool = {
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Type(type_decl) => {
        if (type_decl.id.value == "ParserState" and type_decl.name == "ParserState") {
          return declaration_fixture_has_field(types, type_decl, "offset", "usize") and
            declaration_fixture_has_field(types, type_decl, "source", "String")
        }
      }
      case IrDeclaration.Function(fn_value) => {
      }
    }
  }
  false
}

def declaration_fixture_has_stable_order(ir_module: IrModule): Bool = {
  declaration_id(ir_module.declarations.get(0)).value == "ParserState" and
    declaration_id(ir_module.declarations.get(1)).value == "ParserState.current_byte" and
    declaration_id(ir_module.declarations.get(2)).value == "ParserState.advance" and
    declaration_id(ir_module.declarations.get(3)).value == "parser_state" and
    declaration_id(ir_module.declarations.get(4)).value == "parse_source"
}

def ir_declaration_has_type(ir_module: IrModule, id: String): Bool = {
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Type(type_decl) => {
        if (type_decl.id.value == id) {
          return true
        }
      }
      case IrDeclaration.Function(fn_value) => {
      }
    }
  }
  false
}

def declaration_fixture_has_field(types: TypeStore, type_decl: IrTypeDecl, name: String, expected_type: String): Bool = {
  for (field in type_decl.fields) {
    if (field.name == name and ir_type_display(types, field.typ) == expected_type) {
      return true
    }
  }
  false
}

def declaration_fixture_has_method(ir_module: IrModule, id: String, receiver: String): Bool = {
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Function(fn_value) => {
        if (fn_value.id.value == id and fn_value.owner.is_some()) {
          fn_value.receiver match {
            case Option[IrLocalId]::Some(receiver_id) => {
              if (receiver_id.value == receiver) {
                return true
              }
            }
            case Option[IrLocalId]::None => {
            }
          }
        }
      }
      case IrDeclaration.Type(type_decl) => {
      }
    }
  }
  false
}

def declaration_fixture_has_function(ir_module: IrModule, id: String): Bool = {
  for (declaration in ir_module.declarations) {
    declaration match {
      case IrDeclaration.Function(fn_value) => {
        if (fn_value.id.value == id and fn_value.owner.is_none() and fn_value.receiver.is_none()) {
          return true
        }
      }
      case IrDeclaration.Type(type_decl) => {
      }
    }
  }
  false
}

def ir_lowered_function_has_local(ir_module: IrModule, id: String, local_name: String): Bool = {
  val maybe_fn = find_function(ir_module, ir_decl_id(id));
  maybe_fn match {
    case Option[IrFunction]::Some(fn_value) => {
      for (local in fn_value.locals) {
        if (local.name == local_name) {
          return true
        }
      }
      false
    }
    case Option[IrFunction]::None => {
      false
    }
  }
}

def ir_lowered_function_has_operation_count(ir_module: IrModule, id: String, count: usize): Bool = {
  val maybe_fn = find_function(ir_module, ir_decl_id(id));
  maybe_fn match {
    case Option[IrFunction]::Some(fn_value) => {
      if (fn_value.blocks.is_empty()) {
        return false
      }
      fn_value.blocks.get(0).operations.len() == count
    }
    case Option[IrFunction]::None => {
      false
    }
  }
}

def ir_lowered_function_has_intrinsic(ir_module: IrModule, id: String, name: String): Bool = {
  val maybe_fn = find_function(ir_module, ir_decl_id(id));
  maybe_fn match {
    case Option[IrFunction]::Some(fn_value) => {
      for (block in fn_value.blocks) {
        for (operation in block.operations) {
          operation match {
            case IrOperation.IntrinsicCall(output, intrinsic_name, args, signature) => {
              if (intrinsic_name == name) {
                return true
              }
            }
            case IrOperation.InitLocal(target, value) => {
            }
            case IrOperation.Assign(target, value) => {
            }
            case IrOperation.ConstructType(output, owner, fields) => {
            }
            case IrOperation.DirectCall(output, callee, args, signature) => {
            }
            case IrOperation.FieldGet(output, receiver, field, result_type) => {
            }
            case IrOperation.FieldSet(receiver, field, value) => {
            }
            case IrOperation.Binary(output, op, left, right, result_type) => {
            }
          }
        }
      }
      false
    }
    case Option[IrFunction]::None => {
      false
    }
  }
}

