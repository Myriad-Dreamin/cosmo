def invalid_call_fixture(): IrFixture = {
  val fixture = valid_ir_fixture();
  var types = fixture.types;
  val i32_type = types.alloc_primitive("i32");
  val args = Vec[IrValue]();
  args.push(IrValue.NumericLiteral("1", i32_type));
  args.push(IrValue.NumericLiteral("2", i32_type));
  val param_types = Vec[TypeId]();
  param_types.push(i32_type);
  val operations = Vec[IrOperation]();
  operations.push(IrOperation.DirectCall(
    Option[IrLocalId]::Some(ir_local_id("tmp0")),
    ir_decl_id("identity"),
    args,
    ir_signature(param_types, i32_type)
  ));
  val locals = Vec[IrLocal]();
  locals.push(IrLocal(ir_local_id("tmp0"), "tmp0", i32_type, false));
  val blocks = Vec[IrBlock]();
  blocks.push(IrBlock(
    ir_block_id("entry"),
    operations,
    IrTerminator.Return(Option[IrValue]::Some(IrValue.Local(ir_local_id("tmp0"), i32_type)))
  ));
  val bad = IrFunction(
    ir_decl_id("bad_call"),
    "bad_call",
    Vec[IrParam](),
    i32_type,
    locals,
    blocks,
    Option[IrDeclId]::None,
    Option[IrLocalId]::None
  );
  val declarations = fixture.ir_module.declarations;
  declarations.push(IrDeclaration.Function(bad));
  IrFixture(types, IrModule("bad_call", declarations))
}

