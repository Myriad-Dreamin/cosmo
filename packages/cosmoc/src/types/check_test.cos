  val local_init = arenas.make_numeric_literal_expr("1", make_span(16, 17));
  val local = arenas.make_local_expr("count", false, local_type, local_init, make_span(0, 17));
  val target = arenas.make_name_expr("count", make_span(20, 25));
  val value = arenas.make_numeric_literal_expr("2", make_span(28, 29));
  val assign = arenas.make_assign_expr(target, value, make_span(20, 29));
  val items = Vec[ExprId]();
  items.push(local);
  items.push(assign);
  val body = arenas.make_block_expr(items, make_span(0, 29));
  val return_type = arenas.make_name_type("Unit", make_span(31, 35));
  val decl = arenas.make_function_decl("main", Vec[ParamId](), return_type, body, make_span(0, 35));
  val declarations = Vec[DeclId]();
  declarations.push(decl);
  val root = arenas.make_module(declarations, make_span(0, 35));

  val checked = check_module_basic_expressions(arenas, root);
  !checked.is_ok() and
    checked.first_diagnostic_code() == "cosmo1.type.immutable-assignment" and
    typed_expr_has_primitive(checked, assign, "Unit")
}

