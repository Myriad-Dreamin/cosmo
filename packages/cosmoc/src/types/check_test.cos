def basic_expression_checker_accepts_inferable_unit_body(): Bool = {
  var arenas = syntax_arenas();

  val callee = arenas.make_name_expr("println", make_span(15, 22));
  val arg = arenas.make_string_literal_expr("ok", make_span(23, 27));
  val args = Vec[ExprId]();
  args.push(arg);
  val call = arenas.make_call_expr(callee, args, make_span(15, 28));
  val items = Vec[ExprId]();
  items.push(call);
  val body = arenas.make_block_expr(items, make_span(13, 30));
  val return_type = arenas.make_missing_type(make_span(3, 7));
  val decl = arenas.make_function_decl("main", Vec[ParamId](), return_type, body, make_span(0, 30));
  val declarations = Vec[DeclId]();
  declarations.push(decl);
  val root = arenas.make_module(declarations, make_span(0, 30));

  val checked = check_module_basic_expressions(arenas, root);
  checked.is_ok() and
    typed_expr_has_primitive(checked, call, "Unit") and
    typed_expr_has_primitive(checked, body, "Unit")
}

