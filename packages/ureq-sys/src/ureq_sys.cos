private def unsafe_ureq_sys_request_send_text(
  request: Ptr[UreqSysRawRequest],
  body_ptr: Ptr[u8],
  body_len: usize
): UreqSysResponseResult

@extern("c", name = "cosmo_ureq_sys_request_send_bytes", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_request_send_bytes(
  request: Ptr[UreqSysRawRequest],
  body_ptr: Ptr[u8],
  body_len: usize
): UreqSysResponseResult

@extern("c", name = "cosmo_ureq_sys_request_release", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_request_release(request: Ptr[UreqSysRawRequest]): Unit

@extern("c", name = "cosmo_ureq_sys_response_status", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_response_status(response: Ptr[UreqSysRawResponse]): u16

@extern("c", name = "cosmo_ureq_sys_response_status_text", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_response_status_text(response: Ptr[UreqSysRawResponse]): UreqSysBytesResult

@extern("c", name = "cosmo_ureq_sys_response_header", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_response_header(
  response: Ptr[UreqSysRawResponse],
  name_ptr: Ptr[u8],
  name_len: usize
): UreqSysHeaderResult

@extern("c", name = "cosmo_ureq_sys_response_body_text", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_response_body_text(response: Ptr[UreqSysRawResponse]): UreqSysBytesResult

@extern("c", name = "cosmo_ureq_sys_response_body_bytes", supportLibrary = "ureq-sys")
private def unsafe_ureq_sys_response_body_bytes(response: Ptr[UreqSysRawResponse], max_bytes: usize): UreqSysBytesResult

