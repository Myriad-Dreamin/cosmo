{
  "name": "cosmo",
  "version": "0.1.0",
  "description": "An integrated language service for Cosmo",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Myriad-Dreamin/cosmo"
  },
  "displayName": "Cosmo",
  "author": "Myriad-Dreamin",
  "contributors": [
    "Myriad-Dreamin"
  ],
  "publisher": "myriad-dreamin",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.82.0"
  },
  "main": "./out/extension.js",
  "icon": "./icons/cosmo-small.png",
  "contributes": {
    "configurationDefaults": {
      "[cosmo]": {
        "editor.wordWrap": "on",
        "editor.semanticHighlighting.enabled": true,
        "editor.tabSize": 2,
        "editor.inlayHints.enabled": "off"
      }
    },
    "languages": [
      {
        "id": "cosmo",
        "configuration": "./syntaxes/language-configuration.json",
        "extensions": [
          ".cos",
          ".cos-ast"
        ],
        "aliases": [
          "Cosmo",
          "cosmo",
          "cos"
        ],
        "icon": {
          "light": "./icons/cosmo-small.png",
          "dark": "./icons/cosmo-small.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "cosmo",
        "scopeName": "source.cosmo",
        "path": "./out/cosmo.tmLanguage.json"
      }
    ],
    "commands": []
  },
  "activationEvents": [
    "onLanguage:cosmo"
  ],
  "scripts": {
    "build:syntax": "pnpm --dir ../../syntaxes/textmate run compile && pnpm --dir ../../syntaxes/textmate run bundle",
    "build-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --target=node16",
    "build-host": "esbuild ./src/cosmos-host.ts --bundle --outfile=out/cosmos-host.js --external:vscode --format=cjs --platform=node --sourcemap --target=node16",
    "build-server": "esbuild ./src/lsp-server.ts --bundle --outfile=out/lsp-server.js --external:vscode --format=cjs --platform=node --sourcemap --target=node16",
    "copy-cosmos-package": "node scripts/copy-cosmos-package.mjs",
    "vscode:prepublish": "pnpm run copy-cosmos-package && pnpm run build-base -- --minify && pnpm run build-server -- --minify",
    "package": "vsce package --no-dependencies",
    "compile": "pnpm run compile:extension && pnpm run build:syntax",
    "compile:extension": "pnpm run build-base && pnpm run build-server",
    "test:smoke": "pnpm run build-host && node --test test/*.test.cjs",
    "watch": "pnpm run build-base -- --watch"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/vscode": "^1.82.0",
    "@types/chai": "^4.3.16",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "@types/ws": "^8.5.5",
    "@types/mocha": "^10.0.1",
    "@vscode/vsce": "^2.22.0",
    "@vscode/test-electron": "^2.3.9",
    "mocha": "^10.2.0",
    "chai": "^5.1.1",
    "esbuild": "^0.19.5",
    "eslint": "^8.52.0",
    "typescript": "^5.2.2"
  }
}
